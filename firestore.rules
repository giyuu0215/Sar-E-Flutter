rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each store is isolated by the owner's Firebase UID.
    // Only the authenticated owner can read/write their own store data.
    match /stores/{storeId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == storeId;
    }

  }
}
